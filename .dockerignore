# Build context hygiene — keep the image small and secrets OUT of it.
# node_modules / dist are rebuilt inside the image; certs + .env are provided at
# runtime (compose volume + env_file), never baked in.
node_modules
dist
.git
.gitignore
.env
.env.*
certs
docs
test
coverage
*.log
.agentic-security
**/.agentic-security
.vscode
.idea
README*.md
docker-compose.yml
Dockerfile
.dockerignore
