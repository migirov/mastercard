# Пример конфигурации. Скопируйте в .env и заполните (.env — в .gitignore).
# Ключи Mastercard кладутся в certs/ (тоже в .gitignore) — см. README.md.

# --- Mastercard API ---
# Базовый URL: sandbox / MTF / production
MC_BASE_URL=
# Consumer key с портала Mastercard Developers
MC_CONSUMER_KEY=
# partner-id. В sandbox общий статический SANDBOX_1234567; в prod — свой
MC_PARTNER_ID=

# --- Подпись (OAuth1): приватный .p12 в certs/ ---
MC_SIGNING_KEY_PATH=./certs/your-signing-key.p12
MC_SIGNING_KEY_PASSWORD=

# --- Шифрование (JWE / field-level encryption) ---
# Направление ключей (НЕ перепутать — обратный выбор даёт ошибку 082000 Crypto Key):
#   запрос шифруем Client Encryption Key (публичный cert MC), а ответ
#   расшифровываем НАШИМ Mastercard Encryption private key.
# Публичный cert Client Encryption Key — им шифруются ЗАПРОСЫ
MC_ENCRYPTION_CERT_PATH=./certs/client-encryption-cert.pem
# Fingerprint публичного ключа шифрования = 64-hex SHA-256 (kid запроса)
MC_ENCRYPTION_FINGERPRINT=
# false = plain passthrough; true = JWE. FLE работает во ВСЕХ средах, включая
# sandbox (подтверждено 2026-06-16) — включайте, как только настроены ключи.
MC_ENCRYPTION_ENABLED=false
# Наш приватный Mastercard Encryption key (PEM) для расшифровки ОТВЕТОВ
MC_DECRYPTION_KEY_PATH=

# (Только для PoC-скриптов scripts/encrypt-poc.ts — рантайм это НЕ читает)
MC_ENCRYPTION_KEY_PATH=
MC_ENCRYPTION_KEY_PASSWORD=

# --- Merchant secret store: local (dev) | aws-secrets-manager (prod) ---
MC_SECRET_STORE=local
# AWS region for the secret store (optional; the SDK otherwise uses AWS_REGION / the IAM role)
MC_SECRET_STORE_REGION=

# --- Auth (dev-значения; в production прод-гейт требует сильные, см. main.ts) ---
# Секрет подписи JWT access-token'ов (OAuth2)
MC_JWT_SECRET=
# Токен для внутренних сервисов (X-Internal-Token)
MC_INTERNAL_TOKEN=
# Токен admin-API (X-Admin-Token)
MC_ADMIN_TOKEN=
# Webhook shared token — OPTIONAL secondary/dev factor (fail-closed when mTLS is off).
# In prod the authoritative factor is in-app mTLS (below); MC sends no token on push.
MC_WEBHOOK_TOKEN=

# --- Webhook auth: in-app mTLS (validate MC's client cert in the app, not the ingress) ---
# Enable in-app client-cert validation. REQUIRED in production (prod gate in main.ts).
MC_WEBHOOK_MTLS_ENABLED=false
# Allowlist of acceptable MC client-cert subject CNs (comma-separated).
# Prod: CrossborderServicesNotification-prod.mastercard.com ; MTF: ...-mtf.mastercard.com
MC_WEBHOOK_ALLOWED_CLIENT_CNS=
# Server TLS so the app terminates TLS (mTLS) itself; ingress = L4 passthrough.
# CA = MC's DigiCert Outbound chain (Assured ID Client CA G2 + Root G2).
TLS_KEY_PATH=
TLS_CERT_PATH=
TLS_CLIENT_CA_PATH=

# --- Сеть ---
# Доверять X-Forwarded-* за прокси/LB: число хопов ингресса (НЕ 'true'). Пусто = off
TRUST_PROXY=

# --- PostgreSQL ---
DATABASE_URL=postgres://mc:mc@localhost:5432/mc_gateway
# Размер пула БД ПЕР-ПОД (подов × DB_POOL_MAX не должно превышать max_connections)
DB_POOL_MAX=10
# Авто-прогон миграций на старте (в multi-pod лучше отдельным Job/init-container)
# DB_MIGRATIONS_RUN=false

# --- Логи ---
# Уровень pino-логов: trace|debug|info|warn|error (по умолчанию info)
# LOG_LEVEL=info

# --- Опционально ---
# NODE_ENV=production
# SWAGGER_ENABLED=true        # включить Swagger в production
# PORT=3000
# MC_CREDS_CACHE_TTL_MS=600000  # TTL кэша OWN-credentials
