# Example configuration. Copy to .env and fill in (.env is in .gitignore).
# Mastercard keys go in certs/ (also in .gitignore) — see README.md.

# --- Mastercard API ---
# Base URL: sandbox / MTF / production
MC_BASE_URL=
# Consumer key from the Mastercard Developers portal
MC_CONSUMER_KEY=
# partner-id. Sandbox uses the shared static SANDBOX_1234567; prod uses your own
MC_PARTNER_ID=

# --- Signing (OAuth1): private .p12 in certs/ ---
MC_SIGNING_KEY_PATH=./certs/your-signing-key.p12
MC_SIGNING_KEY_PASSWORD=

# --- Encryption (JWE / field-level encryption) ---
# Key direction (do NOT swap — the reverse choice yields the 082000 Crypto Key error):
#   encrypt the REQUEST with the Client Encryption Key (MC's public cert), and
#   decrypt the RESPONSE with OUR Mastercard Encryption private key.
# Public cert of the Client Encryption Key — used to encrypt REQUESTS
MC_ENCRYPTION_CERT_PATH=./certs/client-encryption-cert.pem
# Fingerprint of the public encryption key = 64-hex SHA-256 (the request kid)
MC_ENCRYPTION_FINGERPRINT=
# false = plain passthrough; true = JWE. FLE works in ALL environments, including
# sandbox (confirmed 2026-06-16) — enable it once the keys are configured.
MC_ENCRYPTION_ENABLED=false
# Our private Mastercard Encryption key (PEM) for decrypting RESPONSES
MC_DECRYPTION_KEY_PATH=

# (Only for the PoC script scripts/encrypt-poc.ts — the runtime does NOT read these)
MC_ENCRYPTION_KEY_PATH=
MC_ENCRYPTION_KEY_PASSWORD=

# --- Merchant secret store: local (dev) | aws-secrets-manager (prod) ---
MC_SECRET_STORE=local
# AWS region for the secret store (optional; the SDK otherwise uses AWS_REGION / the IAM role)
MC_SECRET_STORE_REGION=

# --- Auth (dev values; in production the prod gate requires strong ones, see main.ts) ---
# Signing secret for the JWT access tokens (OAuth2)
MC_JWT_SECRET=
# Token for internal services (X-Internal-Token)
MC_INTERNAL_TOKEN=
# Admin API token (X-Admin-Token)
MC_ADMIN_TOKEN=
# Webhook shared token — OPTIONAL secondary/dev factor (fail-closed when mTLS is off).
# In prod the authoritative factor is in-app mTLS (below); MC sends no token on push.
MC_WEBHOOK_TOKEN=

# --- Webhook auth: in-app mTLS (validate MC's client cert in the app, not the ingress) ---
# Enable in-app client-cert validation. REQUIRED in production (prod gate in main.ts).
MC_WEBHOOK_MTLS_ENABLED=false
# Allowlist of acceptable MC client-cert subject CNs (comma-separated).
# Prod: CrossborderServicesNotification-prod.mastercard.com ; MTF: ...-mtf.mastercard.com
MC_WEBHOOK_ALLOWED_CLIENT_CNS=
# Server TLS so the app terminates TLS (mTLS) itself; ingress = L4 passthrough.
# CA = MC's DigiCert Outbound chain (Assured ID Client CA G2 + Root G2).
TLS_KEY_PATH=
TLS_CERT_PATH=
TLS_CLIENT_CA_PATH=

# --- Network ---
# Trust X-Forwarded-* behind a proxy/LB: the number of ingress hops (NOT 'true'). Empty = off
TRUST_PROXY=

# --- PostgreSQL ---
DATABASE_URL=postgres://mc:mc@localhost:5432/mc_gateway
# DB pool size PER POD (pods x DB_POOL_MAX must not exceed max_connections)
DB_POOL_MAX=10
# Auto-run migrations on startup (in multi-pod, prefer a separate Job/init-container)
# DB_MIGRATIONS_RUN=false

# --- Logs ---
# pino log level: trace|debug|info|warn|error (default info)
# LOG_LEVEL=info

# --- Optional ---
# NODE_ENV=production
# SWAGGER_ENABLED=true        # enable Swagger in production
# PORT=3000
# MC_CREDS_CACHE_TTL_MS=600000  # TTL of the OWN-credentials cache
