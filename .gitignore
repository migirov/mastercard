# ──────────────────────────────────────────────────────────────────────────
# Monorepo root .gitignore. Applies across all components:
#   mastercard/ (gateway) · app-bff/ · mastercard-bff/ · masrtercard-front/ ·
#   mastercard-demo-stack/
# Each component may add its own nested .gitignore; this root is the safety net.
# ──────────────────────────────────────────────────────────────────────────

# ── Secrets — NEVER commit (repo is public) ─────────────────────────────────
**/.env
**/.env.*
# …except value-less templates
!**/.env.example
**/secrets.local.json

# Mastercard crypto material (keys + certificates)
**/certs/
**/*.p12
**/*.pem
**/*.key

# ── Dependencies / build output ─────────────────────────────────────────────
**/node_modules/
**/dist/
**/build/
**/.vite/
**/coverage/

# ── Logs / temp artifacts ───────────────────────────────────────────────────
*.log
startup*.log
*.out
*.tmp

# ── Tooling / editor ────────────────────────────────────────────────────────
**/.agentic-security/
.vscode/
.idea/
.DS_Store
