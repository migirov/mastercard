# Секреты — не коммитить
.env
.env.*
# ...кроме шаблона без значений
!.env.example

# Криптоматериал Mastercard (ключи и сертификаты)
certs/
*.p12
*.pem
*.key

# Локальные секреты мерчантов (dev SecretStore)
secrets.local.json

# Сборка / зависимости
dist/
node_modules/

# Тестовое покрытие
coverage/

# Логи и временные артефакты
*.log
startup*.log
*.out
*.tmp

# Вывод/кэш сканера agentic-security (инструментальный, не версионируем)
.agentic-security/

# Internal dev/process docs — kept locally, not versioned
docs/*/memory.md
docs/*/plan.md
docs/*/issues.md
docs/*/tests.md
docs/*/tests-inner.md
docs/*/client-questions.md
docs/*/fund-operations.md
