# mastercard-demo-stack — environment template. Copy to `.env` and fill in.
# The real `.env` is git-ignored (it carries a shared secret).

# Internal token the BFFs present to the gateway. MUST equal MC_INTERNAL_TOKEN in
# ../mastercard/.env — otherwise live gateway calls 401 and silently fall back to demo.
GATEWAY_INTERNAL_TOKEN=replace-with-shared-internal-token

# Tenant the gateway resolves for these calls (the dev harness seeds `platform`).
GATEWAY_TENANT_ID=platform

# Per-capability live/demo switch. `live` proxies the real Mastercard sandbox via the
# gateway; `demo` synthesizes locally. Defaults below match docker-compose.yml.
XBS_QUOTE_MODE=demo
XBS_VALIDATION_MODE=live
XBS_BALANCES_MODE=live
XBS_PAYMENT_MODE=demo
XBS_STATUS_MODE=demo
