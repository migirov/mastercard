# app-bff configuration. All vars are optional — the defaults shown target the shared
# compose Postgres (its own `mc_demo` database). The app-bff is the permanent frontend
# backend (entity store + auth + integrations); it does NOT talk to Mastercard.

# --- runtime ---
NODE_ENV=development
PORT=4000

# --- app data database (its OWN db `mc_demo`; never the gateway's `mc_gateway`) ---
DEMO_DB_HOST=postgres
DEMO_DB_PORT=5432
DEMO_DB_USER=mc
DEMO_DB_PASSWORD=mc
DEMO_DB_NAME=mc_demo
