# mastercard-bff configuration. All vars are optional — the defaults target the sibling
# gateway service `app`. This BFF is STATELESS (no database): it only proxies cross-border
# calls to the Mastercard gateway (live) or synthesizes them (demo), per capability.

# --- runtime ---
NODE_ENV=development
PORT=4000

# --- cross-border gateway (sibling `mastercard` service) ---
GATEWAY_URL=http://app:3000
GATEWAY_INTERNAL_TOKEN=
# The gateway's baseline ACTIVE tenant (seeded on boot). Live calls 404 with an unseeded id.
GATEWAY_TENANT_ID=platform

# --- per-capability live|demo switch (defaults in parens) ---
XBS_QUOTE_MODE=demo          # (demo) — sandbox returns a stub rate (777)
XBS_VALIDATION_MODE=live     # (live)
XBS_BALANCES_MODE=live       # (live)
XBS_PAYMENT_MODE=demo        # (demo) — needs MTF/Prod
XBS_STATUS_MODE=demo         # (demo) — needs MTF/Prod

# --- per-feature live|demo switch (the "Features" pages) ---
XBS_BANK_LOOKUP_MODE=live    # (live)
XBS_IBAN_MODE=live           # (live)
XBS_CASH_PICKUP_MODE=live    # (live)
XBS_RATES_MODE=demo          # (demo)
XBS_ENDPOINT_GUIDE_MODE=demo # (demo)
XBS_QUOTE_LIFECYCLE_MODE=demo
XBS_PAYMENT_TRACKER_MODE=demo
XBS_RFI_MODE=demo
